# Required for restricted surfaces (admin/console/issuance). Use a strong random value (min 12 chars).
QARAQUTU_ACCESS_TOKEN=change_me_to_a_strong_token

# Copy to .env and set real values. Do not commit .env.
DATABASE_URL=postgresql://user:password@host:5432/dbname
SMOKE_BASE_URL=http://localhost:4100

# Atlas preview: set in Vercel (Preview) to the exact deployment URL for branch preacceptance.
# NEXT_PUBLIC_VERIFIER_PREVIEW_URL=https://<project>-git-preacceptance-<team>.vercel.app
